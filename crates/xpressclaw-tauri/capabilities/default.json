{
  "identifier": "default",
  "description": "Default permissions for xpressclaw desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-image",
    "dialog:default",
    "fs:default",
    "opener:default"
  ]
}
