#!/usr/bin/env bash
# Run cargo fmt and clippy before committing.
# Install: git config core.hooksPath .githooks

if ! cargo fmt --all -- --check 2>/dev/null; then
    echo ""
    echo "ERROR: cargo fmt check failed. Run 'cargo fmt' and re-commit."
    echo ""
    exit 1
fi

if ! cargo clippy -p xpressclaw-core -p xpressclaw-server -p xpressclaw-cli -p xpressclaw-tauri -- -D warnings 2>/dev/null; then
    echo ""
    echo "ERROR: clippy failed. Fix warnings and re-commit."
    echo ""
    exit 1
fi
