# Build settings
build --incompatible_strict_action_env
# Pass through PATH so build scripts can find cmake, pkg-config, etc.
build --action_env=PATH

# Rust clippy (enable when needed, disabled by default to avoid lint errors on deps)
# build --aspects=@rules_rust//rust:defs.bzl%rust_clippy_aspect
# build --output_groups=+clippy_checks

# Platform configs for cross-compilation
build:macos-arm64 --platforms=@rules_rust//rust/platform:aarch64-apple-darwin
build:macos-x64 --platforms=@rules_rust//rust/platform:x86_64-apple-darwin

# Speed: use disk cache
build --disk_cache=~/.cache/bazel-disk

# Test settings
test --test_output=errors
