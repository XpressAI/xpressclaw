# Frontend SvelteKit build
exports_files([
    "package.json",
    "package-lock.json",
])

genrule(
    name = "build",
    srcs = glob([
        "src/**",
        "static/**",
        "*.config.*",
        "*.json",
        "postcss.config.js",
    ]),
    outs = ["build_stamp"],
    cmd = """
        set -e
        OUT_FILE="$$PWD/$@"
        FRONTEND=$$(cd $$(dirname $(location package.json)) && pwd -P)
        cd "$$FRONTEND"
        npm ci --silent 2>/dev/null
        npm run build 2>&1
        echo "built" > "$$OUT_FILE"
    """,
    local = True,
    visibility = ["//visibility:public"],
)
